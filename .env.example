# OpenRouter API Key (required for reference stack)
OPENROUTER_API_KEY=sk-or-v1-...

# CMS API authentication key (required — generate with: openssl rand -hex 32)
CMS_API_KEY=dev-local-key

# Storage backend: fs | sftp | git | s3
STORAGE_BACKEND=fs

# --- fs backend (default) ---
DATA_ROOT=/app/data

# --- sftp backend ---
# SFTP_HOST=vps.example.com
# SFTP_PORT=22
# SFTP_USER=capuzzella
# SFTP_KEY_PATH=/keys/id_ed25519
# SFTP_REMOTE_ROOT=/var/www/site

# --- git backend ---
# GIT_REMOTE=git@github.com:you/yoursite.git
# GIT_BRANCH=main
# GIT_KEY_PATH=/keys/id_ed25519
# GIT_AUTHOR_NAME=Capuzzella CMS
# GIT_AUTHOR_EMAIL=cms@example.com
# GIT_CLONE_DIR=/app/repo

# --- s3 backend (AWS S3, Cloudflare R2, MinIO) ---
# S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
# S3_REGION=auto
# S3_BUCKET=your-bucket
# S3_ACCESS_KEY_ID=...
# S3_SECRET_ACCESS_KEY=...
# S3_KEY_PREFIX=site
# S3_PUBLIC_URL=https://your-site.example.com
# S3_CACHE_CONTROL=public, max-age=60

# Open WebUI (reference stack only)
OPENAI_API_BASE_URL=https://openrouter.ai/api/v1
WEBUI_SECRET_KEY=dev-secret-change-me
WEBUI_URL=http://localhost:8081
ENABLE_SIGNUP=true
DEFAULT_MODELS=openai/gpt-4o-mini
