# OpenRouter API Key (required)
OPENROUTER_API_KEY=sk-or-v1-...

# API Base URL for LLM provider
OPENAI_API_BASE_URL=https://openrouter.ai/api/v1

# CMS API authentication key
CMS_API_KEY=dev-local-key

# Open WebUI secret key (change in production)
WEBUI_SECRET_KEY=dev-secret-change-me

# Open WebUI URL (used for redirects)
WEBUI_URL=http://localhost:8081

# Allow signup on first use (disable in production)
ENABLE_SIGNUP=true

# Default LLM models available in Open WebUI
DEFAULT_MODELS=openai/gpt-4o-mini
